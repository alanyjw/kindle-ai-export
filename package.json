{
  "name": "kindle-ai-export",
  "private": true,
  "version": "0.1.0",
  "description": "Export any Kindle book you own as text, PDF, EPUB, or as a custom, AI-narrated audiobook.",
  "author": "Travis Fischer <travis@transitivebullsh.it>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/transitive-bullshit/kindle-ai-export.git"
  },
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "scripts": {
    "test": "run-s test:*",
    "test:format": "prettier --check \"**/*.{js,ts,tsx}\"",
    "test:format:fix": "prettier --write \"**/*.{js,ts,tsx}\"",
    "test:lint": "eslint .",
    "test:lint:fix": "eslint --fix .",
    "test:typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@napi-rs/canvas": "^0.1.80",
    "dotenv": "^16.4.5",
    "fluent-ffmpeg": "^2.1.3",
    "globby": "^14.0.2",
    "hash-object": "^5.0.1",
    "hh-mm-ss": "^1.2.0",
    "kindle-api-ky": "^1.0.1",
    "ky": "^1.7.2",
    "node-id3": "^0.2.6",
    "openai-fetch": "^3.3.1",
    "p-map": "^7.0.2",
    "pdfjs-dist": "^5.4.449",
    "pdfkit": "^0.15.0",
    "playwright": "^1.57.0",
    "playwright-core": "^1.57.0",
    "unrealspeech-api": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/fluent-ffmpeg": "^2.1.26",
    "@types/hh-mm-ss": "^1.2.3",
    "@types/node": "^22.19.3",
    "@types/pdfkit": "^0.13.5",
    "del-cli": "^6.0.0",
    "delay": "^6.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "npm-run-all2": "^6.2.2",
    "only-allow": "^1.2.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "4.0.16"
  }
}